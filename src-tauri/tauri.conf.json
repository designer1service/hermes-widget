{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hermes Widget",
  "version": "0.1.0",
  "identifier": "com.hermes.widget",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Hermes Widget",
        "width": 320,
        "height": 380,
        "minWidth": 320,
        "minHeight": 190,
        "maxWidth": 320,
        "maxHeight": 540,
        "transparent": false,
        "decorations": false,
        "visible": true,
        "resizable": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "shadow": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
